---
import { Image } from "astro:assets";
import Base from "@/layouts/Base.astro";
import Cta from "@/layouts/components/Cta.astro";
import Post from "@/layouts/partials/Post.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import { markdownify } from "@/lib/utils/textConverter";
import { getEntry } from "astro:content";

const homepage = await getEntry("homepage", "index");
const { banner, feature, workflow, call_to_action } = homepage.data;

const posts = await getSinglePage("blog");
const sortedPosts = sortByDate(posts);
const recentPosts = sortedPosts.slice(0, 3);
---

<Base
  title="The Data Lakehouse Hub"
  meta_title="Data Lakehouse Hub | News, Community, Apache Iceberg & Lakehouse Architecture"
  description="News, newsletters, and community for the data lakehouse ecosystem. Weekly roundups, deep dives into Apache Iceberg, and expert guides from practitioners."
  canonical="https://datalakehousehub.com/"
>
  <!-- banner -->
  <section class="section pt-[70px] pb-[70px] bg-gradient-to-br from-white to-theme-light dark:from-dark dark:to-theme-dark">
    <div class="container">
      <div class="row text-center">
        <div class="mx-auto lg:col-10">
          <h1 class="font-primary font-bold text-4xl lg:text-6xl tracking-tight mb-6 text-dark dark:text-white">{banner?.title}</h1>
          {
            banner?.content && (
              <p class="mt-4 text-lg lg:text-xl text-text dark:text-gray-100 opacity-90 max-w-2xl mx-auto" set:html={markdownify(banner.content)} />
            )
          }

          {
            banner?.button?.enable && (
              <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mt-8">
                <a class="btn btn-primary px-8 py-3 text-lg shadow-lg hover:shadow-xl transition-shadow duration-300" href={banner.button.link}>
                  {banner.button.label}
                </a>
                <a class="btn px-8 py-3 text-lg shadow-lg hover:shadow-xl transition-shadow duration-300 border-2 border-white text-white hover:bg-white hover:text-dark rounded-full" href="/knowledgebase">
                  Explore Knowledge Base
                </a>
              </div>
            )
          }

          {
            banner?.image && (
              <Image
                class="mx-auto mt-16 shadow-2xl rounded-lg border border-border dark:border-dark"
                src={banner?.image}
                width={850}
                height={442}
                alt="banner image"
              />
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section bg-theme-light dark:bg-dark">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold dark:text-white">{markdownify(feature!.title)}</h2>
      </div>
      <div class="mt-8 grid gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          feature!.features.map((item: any, i: number) => (
            <div class="feature-card rounded-2xl bg-white dark:bg-theme-dark p-8 text-center shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-transparent hover:border-primary/20">
              {item.icon && (
                <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 text-primary">
                   <img
                    class="mx-auto"
                    alt={item.icon}
                    src={item.icon}
                    width={32}
                    height={32}
                  />
                </div>
              )}
              <div class="mt-2">
                <p class="h5 font-bold mb-3" set:html={markdownify(item!.name)} />
                <p class="text-text dark:text-light leading-relaxed">{item.content}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Reading List -->
  <section class="section bg-theme-light dark:bg-dark">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold dark:text-white">{homepage.data.reading_list?.title}</h2>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 justify-center">
        {
          homepage.data.reading_list?.books.map((book: any) => (
            <a 
              href={book.link} 
              target="_blank" 
              rel="noopener noreferrer"
              class="group block bg-white dark:bg-theme-dark rounded-xl shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden"
            >
              <div class="relative aspect-[2/3] w-full bg-gray-100 dark:bg-darkmode-theme-light flex items-center justify-center p-4">
                 <Image
                  src={book.image}
                  alt={book.title}
                  width={300}
                  height={450}
                  class="object-contain max-h-full shadow-md group-hover:shadow-xl transition-shadow duration-300"
                />
              </div>
              <div class="p-6 text-center">
                <h3 class="text-xl font-bold font-primary group-hover:text-primary transition-colors">{book.title}</h3>
                <span class="inline-flex items-center text-primary mt-3 text-sm font-semibold">
                  Read Book 
                  <img src="/images/arrow-right.svg" class="ml-1 w-4 h-4" alt="arrow" />
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
  <!-- ./End service -->

  <!-- Workflow -->
  <section class="section pb-0">
    <div class="mb-8 text-center">
      <h2
        class="mx-auto max-w-[400px] font-bold leading-[44px]"
        set:html={workflow?.title}
      />
      <p class="mt-3" set:html={workflow?.description} />
    </div>
    <div class="container">
      <Image
        src={workflow!.image}
        alt="workflow image"
        width={1920}
        height={414}
        class="mx-auto"
      />
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="section bg-theme-light dark:bg-dark">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold dark:text-white">Latest Posts</h2>
      </div>
      <div class="row g-4 justify-center">
        {
          recentPosts.map((post) => (
            <div class="col-12 md:col-6 lg:col-4">
              <Post post={post} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Must Read Articles -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold dark:text-white" style="color:#222">Must Read Articles</h2>
        <p class="mt-4 text-lg max-w-2xl mx-auto dark:text-gray-200" style="color:#555">Deep dives into Apache Iceberg, Agentic AI, and modern Data Lakehouse architecture by Alex Merced.</p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

        <!-- Agentic Analytics -->
        <article class="flex flex-col bg-white dark:bg-theme-dark rounded-2xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-border hover:border-primary/40 overflow-hidden">
          <div class="p-6 flex flex-col flex-1">
            <span class="inline-block text-xs font-semibold uppercase tracking-wide text-primary mb-3">Agentic AI</span>
            <h3 class="font-bold mb-3 dark:text-white" style="font-size:1.15rem;color:#222">Agentic Analytics on the Apache Lakehouse</h3>
            <p class="leading-relaxed flex-1 dark:text-gray-300" style="color:#555">Discover how autonomous AI agents replace manual dashboard querying by reading governed semantic layers directly on your data lakehouse, delivering faster and more reliable analytical results.</p>
            <a href="/blog/2026-04-agentic-analytics" class="btn btn-primary mt-6 text-center">Read Article</a>
          </div>
        </article>

        <!-- What is Apache Iceberg -->
        <article class="flex flex-col bg-white dark:bg-theme-dark rounded-2xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-border hover:border-primary/40 overflow-hidden">
          <div class="p-6 flex flex-col flex-1">
            <span class="inline-block text-xs font-semibold uppercase tracking-wide text-primary mb-3">Apache Iceberg</span>
            <h3 class="font-bold mb-3 dark:text-white" style="font-size:1.15rem;color:#222">What is Apache Iceberg? The Table Format Revolution</h3>
            <p class="leading-relaxed flex-1 dark:text-gray-300" style="color:#555">Learn how Apache Iceberg turned raw Parquet files in S3 into a fully ACID-compliant, time-traveling analytical database without moving your data out of object storage.</p>
            <a href="/blog/2026-04-apache-iceberg" class="btn btn-primary mt-6 text-center">Read Article</a>
          </div>
        </article>

        <!-- State of the Iceberg Ecosystem -->
        <article class="flex flex-col bg-white dark:bg-theme-dark rounded-2xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-border hover:border-primary/40 overflow-hidden">
          <div class="p-6 flex flex-col flex-1">
            <span class="inline-block text-xs font-semibold uppercase tracking-wide text-primary mb-3">Apache Iceberg</span>
            <h3 class="font-bold mb-3 dark:text-white" style="font-size:1.15rem;color:#222">The 2025 State of the Apache Iceberg Ecosystem</h3>
            <p class="leading-relaxed flex-1 dark:text-gray-300" style="color:#555">Survey data from data professionals reveals adoption rates, popular tooling, and where the Apache Iceberg ecosystem is heading through 2026 and beyond.</p>
            <a href="/blog/2026-02-state-of-the-apache-iceberg-ecosystem" class="btn btn-primary mt-6 text-center">Read Article</a>
          </div>
        </article>

        <!-- Table Formats Masterclass -->
        <article class="flex flex-col bg-white dark:bg-theme-dark rounded-2xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-border hover:border-primary/40 overflow-hidden">
          <div class="p-6 flex flex-col flex-1">
            <span class="inline-block text-xs font-semibold uppercase tracking-wide text-primary mb-3">Data Lakehouse</span>
            <h3 class="font-bold mb-3 dark:text-white" style="font-size:1.15rem;color:#222">What Are Table Formats and Why Were They Needed?</h3>
            <p class="leading-relaxed flex-1 dark:text-gray-300" style="color:#555">Table formats like Apache Iceberg solved the ACID, schema evolution, and query performance problems that turned data lakes into unmanageable data swamps.</p>
            <a href="/blog/2026-04-29-apache-iceberg-masterclass-01-table-formats" class="btn btn-primary mt-6 text-center">Read Article</a>
          </div>
        </article>

        <!-- Intro to Iceberg 2026 -->
        <article class="flex flex-col bg-white dark:bg-theme-dark rounded-2xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-border hover:border-primary/40 overflow-hidden">
          <div class="p-6 flex flex-col flex-1">
            <span class="inline-block text-xs font-semibold uppercase tracking-wide text-primary mb-3">Apache Iceberg</span>
            <h3 class="font-bold mb-3 dark:text-white" style="font-size:1.15rem;color:#222">2026 Intro to Apache Iceberg</h3>
            <p class="leading-relaxed flex-1 dark:text-gray-300" style="color:#555">A comprehensive beginner-to-intermediate introduction to Apache Iceberg, covering its metadata layer, catalog integrations, and why it has become the dominant open table format.</p>
            <a href="/blog/2026-02-2026-Intro-to-Apache-Iceberg" class="btn btn-primary mt-6 text-center">Read Article</a>
          </div>
        </article>

        <!-- Semantic Layer and AI -->
        <article class="flex flex-col bg-white dark:bg-theme-dark rounded-2xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-border hover:border-primary/40 overflow-hidden">
          <div class="p-6 flex flex-col flex-1">
            <span class="inline-block text-xs font-semibold uppercase tracking-wide text-primary mb-3">Agentic AI</span>
            <h3 class="font-bold mb-3 dark:text-white" style="font-size:1.15rem;color:#222">Why AI Fails Without a Semantic Layer</h3>
            <p class="leading-relaxed flex-1 dark:text-gray-300" style="color:#555">Explore how a semantic layer provides the business context and governed metrics that AI agents require to generate accurate, trustworthy analytical answers at scale.</p>
            <a href="/blog/2026-02-semantic-layer-05-why-ai-fails-without" class="btn btn-primary mt-6 text-center">Read Article</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <Cta cta={call_to_action} />
</Base>
