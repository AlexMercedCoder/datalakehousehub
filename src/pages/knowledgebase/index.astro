---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";

const posts = await getSinglePage("knowledgebase");
---

<Base title="Knowledge Base">
  <section class="section pt-16">
    <div class="container">
      <h1 class="text-center font-bold text-4xl lg:text-5xl mb-12">
        Knowledge Base
      </h1>

      <div class="mb-12 max-w-2xl mx-auto">
        <input
          type="text"
          id="kb-search-input"
          placeholder="Search glossary terms and definitions..."
          class="w-full px-4 py-3 rounded-lg border border-border dark:border-darkmode-border bg-white dark:bg-darkmode-theme-light text-text dark:text-white focus:ring-primary focus:border-primary transition"
        />
      </div>
      
      <div class="row" id="kb-grid">
        {
          posts.map((post) => (
            <div 
              class="col-12 mb-8 sm:col-6 kb-card" 
              data-title={post.data.title.toLowerCase()} 
              data-desc={post.data.description?.toLowerCase() || ""}
            >
              <div class="bg-theme-light dark:bg-darkmode-theme-light p-8 rounded-lg h-full">
                <h3 class="mb-4">
                  <a href={`/knowledgebase/${post.slug}`} class="text-dark dark:text-light transition hover:text-primary">
                    {post.data.title}
                  </a>
                </h3>
                <p>{post.data.description}</p>
                <a href={`/knowledgebase/${post.slug}`} class="btn btn-outline-primary mt-4">Read Full Definition</a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    const searchInput = document.getElementById('kb-search-input');
    const cards = document.querySelectorAll('.kb-card');

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const query = target.value.toLowerCase();
        
        cards.forEach((card) => {
          const htmlCard = card as HTMLElement;
          const title = htmlCard.getAttribute('data-title') || '';
          const desc = htmlCard.getAttribute('data-desc') || '';
          
          if (title.includes(query) || desc.includes(query)) {
            htmlCard.style.display = 'block';
          } else {
            htmlCard.style.display = 'none';
          }
        });
      });
    }
  </script>
</Base>
